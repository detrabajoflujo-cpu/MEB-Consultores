# ============================================================
# ECOSISTEMA CRM — Variables de Entorno
# Copia este archivo como .env y rellena los valores reales
# ============================================================

# PostgreSQL
POSTGRES_DB=crm_db
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_pass

# n8n
N8N_USER=admin
N8N_PASSWORD=admin123

# WhatsApp Cloud API (Meta)
# Obtener en: developers.facebook.com → App → WhatsApp
WHATSAPP_TOKEN=AQUI_TU_TOKEN_WHATSAPP
WHATSAPP_PHONE_ID=AQUI_TU_PHONE_ID
WHATSAPP_VERIFY_TOKEN=AQUI_TOKEN_VERIFICACION_WEBHOOK

# OpenAI (para OCR con Vision)
# Obtener en: platform.openai.com/api-keys
OPENAI_API_KEY=sk-AQUI_TU_OPENAI_KEY

# Anthropic Claude (alternativa a OpenAI Vision)
ANTHROPIC_API_KEY=sk-ant-AQUI_TU_CLAUDE_KEY

# Bland.ai (Agente de llamadas IA)
# Obtener en: app.bland.ai → API Keys
BLAND_AI_KEY=AQUI_TU_BLAND_KEY

# Vapi.ai (Alternativa a Bland)
VAPI_KEY=AQUI_TU_VAPI_KEY

# Google Cloud Service Account
# Crear en: console.cloud.google.com → IAM → Service Accounts
# Descargar JSON y guardarlo como credentials/google-service-account.json
GOOGLE_DRIVE_FOLDER_ID=AQUI_ID_CARPETA_RAIZ_DRIVE
GOOGLE_SHEETS_ID=AQUI_ID_HOJA_BASE_CAPTURA
# Base Domiciliado Enriquecida (Módulo II — Proforma V4.1)
GOOGLE_SHEETS_DOMICILIADO_ID=AQUI_ID_HOJA_DOMICILIADO_ENRIQUECIDA

# Backend (Spring Boot)
SERVER_PORT=8080
JWT_SECRET=AQUI_TU_JWT_SECRET_MUY_LARGO_Y_SEGURO

# ============================================================
# Agentes Round-Robin — Módulo III (Proforma V4.1 §6)
# Teléfonos de los 6 agentes humanos con código de país (+52...)
# ============================================================
N8N_WEBHOOK_URL=http://n8n:5678
AGENTE_1_TEL=+52XXXXXXXXXX
AGENTE_2_TEL=+52XXXXXXXXXX
AGENTE_3_TEL=+52XXXXXXXXXX
AGENTE_4_TEL=+52XXXXXXXXXX
AGENTE_5_TEL=+52XXXXXXXXXX
AGENTE_6_TEL=+52XXXXXXXXXX

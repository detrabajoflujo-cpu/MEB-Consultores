    {
      "parameters": {
        "jsCode": "const binaryData = await this.helpers.getBinaryDataBuffer(0, 'data');\nconst base64 = binaryData.toString('base64');\nconst mimeType = $input.first().binary.data.mimeType;\n\nreturn [{\n  json: {\n    ...$input.first().json,\n    base64Image: `data:${mimeType};base64,${base64}`\n  },\n  binary: $input.first().binary\n}];"
      },
      "id": "convert-base64",
      "name": "Convertir a Base64",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        -100
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT p.curp FROM prospectos p WHERE p.telefono_contacto = '{{ $('Extraer Media ID').first().json.phone }}';"
      },
      "id": "get-curp",
      "name": "Obtener CURP",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.3,
      "position": [
        1000,
        -100
      ],
      "credentials": {
        "postgres": {
          "id": "ugn76S3Zqub01cyD",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{$env[\"OPENAI_API_KEY\"]}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": [\n        {\n          \"type\": \"text\",\n          \"text\": \"Extrae de este documento financiero (Resolución de Pensión u Hoja Amarilla):\\n1. Monto de pensión (sólo el número mayor a 0, sin comas ni símbolos).\\n2. Banco detectado (ej. BBVA, BANAMEX, BANORTE, SANTANDER, HSBC, AZTECA, COPPEL). Si no está claro, pon null.\\n3. Retenciones detectadas (sólo el número, si no hay pon 0).\\nDevuelve ÚNICAMENTE un JSON válido con estas claves: \\\"monto_pension\\\" (number), \\\"banco_detectado\\\" (string o null), \\\"retenciones_detectadas\\\" (number).\"\n        },\n        {\n          \"type\": \"image_url\",\n          \"image_url\": {\n            \"url\": \"{{ $('Convertir a Base64').first().json.base64Image }}\"\n          }\n        }\n      ]\n    }\n  ],\n  \"max_tokens\": 300\n}"
      },
      "id": "openai-vision",
      "name": "OpenAI Vision OCR",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1200,
        -100
      ]
    },
    {
      "parameters": {
        "jsCode": "const contentStr = $input.first().json.choices[0].message.content;\nlet ocr = {};\ntry {\n  const jsonStr = contentStr.replace(/```json/g, '').replace(/```/g, '').trim();\n  ocr = JSON.parse(jsonStr);\n} catch(e) {\n  ocr = { monto_pension: 0, banco_detectado: null, retenciones_detectadas: 0 };\n}\n\nconst monto = ocr.monto_pension || 0;\nconst banco = ocr.banco_detectado ? ocr.banco_detectado.toUpperCase() : '';\nconst retenciones = ocr.retenciones_detectadas || 0;\n\nlet tipoCredito = '';\nlet viable = false;\n\nconst bancosAutorizados = ['BBVA', 'BANAMEX', 'BANORTE', 'SANTANDER', 'HSBC'];\n\nif (monto > 5000 && retenciones === 0) {\n    tipoCredito = 'NOMINA';\n    viable = true;\n} else if (bancosAutorizados.some(b => banco.includes(b))) {\n    tipoCredito = 'DOMICILIADO';\n    viable = true;\n}\n\nreturn [{ json: { monto: monto, banco: banco, retenciones: retenciones, tipoCredito: tipoCredito, viable: viable } }];"
      },
      "id": "evaluar-reglas",
      "name": "Evaluar Reglas Negocio",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1400,
        -100
      ]
    },
    {
      "parameters": {
        "method": "PUT",
        "url": "=http://backend:8080/api/expedientes/curp/{{ $('Obtener CURP').first().json.curp }}/calificacion",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"montoPension\": {{$json.monto}}, \"institucionBancaria\": \"{{$json.banco}}\", \"tipoCredito\": \"{{$json.tipoCredito}}\", \"retenciones\": {{$json.retenciones}}, \"viable\": {{$json.viable}} }"
      },

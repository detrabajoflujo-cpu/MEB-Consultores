{
  "name": "Módulo 2: Calificación Financiera",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "modulo2-ingesta",
        "options": {}
      },
      "id": "webhook-ingesta",
      "name": "Webhook Modulo 2",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const inputData = $input.first().json.body || $input.first().json;\nconst payload = inputData.payload;\nconst phone = inputData.phone;\nconst msg = payload.entry[0].changes[0].value.messages[0];\n\nlet mediaId = null;\nlet mediaType = null;\nif (msg.image) {\n    mediaId = msg.image.id;\n    mediaType = 'image';\n} else if (msg.document) {\n    mediaId = msg.document.id;\n    mediaType = 'document';\n}\n\nreturn [{ json: { phone: phone, mediaId: mediaId, mediaType: mediaType, payload: payload } }];"
      },
      "id": "extraer-media",
      "name": "Extraer Media ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        200,
        0
      ]
    },
    {
      "parameters": {
        "dataType": "boolean",
        "value1": "={{ $json.mediaId ? true : false }}",
        "rules": {
          "rules": [
            {
              "value2": true,
              "output": 0
            },
            {
              "value2": false,
              "output": 1
            }
          ]
        }
      },
      "id": "switch-media",
      "name": "¿Tiene Media?",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [
        400,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v17.0/{{ $('Webhook Modulo 2').first().json.body.payload.entry[0].changes[0].value.metadata.phone_number_id }}/messages",

        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{ $('Extraer Media ID').first().json.phone }}\",\n  \"type\": \"interactive\",\n  \"interactive\": {\n    \"type\": \"button\",\n    \"body\": {\n      \"text\": \"¡Felicidades! 🎉 Hemos evaluado tu documento y eres APTO para el trámite de aumento de pensión bajo el esquema *{{ $('Evaluar Reglas Negocio').first().json.tipoCredito }}*.\\n\\n¿Desea continuar con el trámite?\"\n    },\n    \"action\": {\n      \"buttons\": [\n        {\n          \"type\": \"reply\",\n          \"reply\": {\n            \"id\": \"SI_CONTINUAR\",\n            \"title\": \"Sí, continuar\"\n          }\n        },\n        {\n          \"type\": \"reply\",\n          \"reply\": {\n            \"id\": \"NO_CONTINUAR\",\n            \"title\": \"No, gracias\"\n          }\n        }\n      ]\n    }\n  }\n}"

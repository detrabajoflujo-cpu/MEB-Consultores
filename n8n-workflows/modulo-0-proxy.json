          "id": "ugn76S3Zqub01cyD",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const phone = $('Limpiar N\u00famero').first().json.phone;\nconst payload = $('Limpiar N\u00famero').first().json.payload;\nconst dbResult = $input.first().json;\n\nlet current_module = 'MODULO_1';\nlet current_step = 'NUEVO_LEAD';\n\nif (dbResult && dbResult.current_module) {\n    current_module = dbResult.current_module;\n    current_step = dbResult.current_step;\n}\n\nreturn [{ json: { phone: phone, current_module: current_module, current_step: current_step, payload: payload } }];"
      },

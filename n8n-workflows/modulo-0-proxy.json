    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\ntry {\n  const message = body.entry?.[0]?.changes?.[0]?.value?.messages?.[0];\n  if (!message) return []; // Detener el flujo si es una notificacin de estado (ledo, entregado)\n  \n  let fromPhone = message.from || '';\n  if (fromPhone.startsWith('521') && fromPhone.length === 13) {\n      fromPhone = fromPhone.replace(/^521/, '52');\n  }\n  return [{ json: { phone: fromPhone, payload: body } }];\n} catch(e) {\n  return [{ json: { error: e.message } }];\n}"
      },
      "id": "limpiar-datos",
      "name": "Limpiar N\u00famero",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        0
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT current_module, current_step FROM bot_sessions WHERE phone_number = '{{ $json.phone }}';",
        "options": {}
      },
      "id": "postgres-query",
      "name": "Consultar Estado en DB",
      "type": "n8n-nodes-base.postgres",
